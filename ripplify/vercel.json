{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://sokostack.ddns.net/api/ripplify/$1" },
    { "source": "/auth/(.*)", "destination": "https://sokostack.ddns.net/api/ripplify/auth/$1" }
  ]
}
